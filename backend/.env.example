AI_OPS_APP_NAME=AI Operations Automation API
AI_OPS_APP_ENVIRONMENT=local
AI_OPS_LOG_LEVEL=INFO
AI_OPS_API_V1_PREFIX=/api/v1

# Local development/testing only; matches compose.yaml and is not a production credential.
AI_OPS_DATABASE_URL=postgresql+psycopg://ai_ops_local:ai_ops_local_password@127.0.0.1:55432/ai_ops_local

# Nonproduction placeholders. Tests use local keys; no real Supabase project is required.
AI_OPS_SUPABASE_ISSUER=https://example.supabase.co/auth/v1
AI_OPS_SUPABASE_AUDIENCE=authenticated
AI_OPS_SUPABASE_JWKS_URL=https://example.supabase.co/auth/v1/.well-known/jwks.json
AI_OPS_JWKS_CACHE_SECONDS=300
AI_OPS_MACHINE_CLOCK_SKEW_SECONDS=300
AI_OPS_MACHINE_NONCE_RETENTION_SECONDS=600
